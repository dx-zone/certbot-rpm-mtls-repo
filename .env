# ==============================================================================
# 🚀 PROJECT INFRASTRUCTURE CONFIGURATION
# ==============================================================================

# ==============================================================================
# ⚠️  MAINTENANCE NOTES:
# - Changes to REPO_FQDN require a 'docker compose restart' and cert renewal.
# - Ensure secrets/rpmrepo-secrets/certificate/generate_mtls_client_ca.sh is run 
#   after changing CA_NAME or CLIENT_NAME to sync the PKI material.
# ==============================================================================

# 🌐 REPO_FQDN: The primary domain for the RPM Repository.
# 1. Used by 'rpmrepo' (Apache) to set ServerName and SSL paths.
# 2. MUST exist in 'certbot/certificates.csv' for automated LE issuance.
# 3. Used by 'client-test' to resolve the repository location.
REPO_FQDN=repo.example.com

# 🛡️  CA_NAME: The "Common Name" (CN) for your internal Client-Auth Root CA.
# This name appears in the system trust store on Linux clients.
# NOTE: Avoid special characters; keep it descriptive for 'trust list' logs.
CA_NAME="Internal-RPM-Repo-CA"

# 👤 CLIENT_NAME: The identity/filename for the test client certificate.
# In production, this is typically overridden by the host's actual hostname.
CLIENT_NAME="mtls-client-identity"

# 📁 Paths for mTLS configuration files and certificates. These are used by the API server to enforce client authentication and secure communication.
API_MTLS_CLIENTS_FILE="./api/mtls-api-clients.txt"

# 🌐 The IPs allowed to access the API server. This is an additional layer of security to restrict access to known IP addresses, complementing the mTLS client authentication.
# This file should contain the IP addresses of any clients that are allowed or denied to connect to the API server, one per line. Ensure that this file is kept up to date with the correct IP addresses of your clients to prevent unauthorized access while allowing legitimate clients to connect successfully.
API_MTLS_IPS_FILE="./api/mtls-api-clients-ip.txt"

# 🗝️ Paths to the CA certificate and client certificates for mTLS. These are critical for the API server to validate client identities and establish secure connections. Ensure these paths are correct and that the certificates are properly generated and stored in these locations.
# The CA certificate file is used by the API server to verify the client certificates presented during the mTLS handshake. The client certificate and key files are used by the API server to present its own identity to clients and establish a secure connection. Make sure that the CA certificate is properly distributed to all clients that need to connect to the API server, and that the client certificates are generated with the correct Common Name (CN) that matches what the API server expects for authentication. 
API_MTLS_CA_FILE="./secrets/rpmrepo-secrets/pki_mtls_material/ca.crt"

# 📝 The certificate and key files for the API server's own TLS configuration. These should be the same certificates that are used by the Apache server in the 'rpmrepo' container, as they need to match the REPO_FQDN for proper SSL/TLS operation. Make sure these files are kept secure and have the correct permissions set, as they are critical for the security of your API server.
# The certificate file should contain the full certificate chain (including any intermediate certificates) to ensure that clients can properly validate the server's identity. The key file should be kept secure and should not be shared or exposed, as it is used to establish the server's identity and encrypt communications. Ensure that both files are correctly referenced in your API server configuration and that they are properly generated and stored in the specified locations.
API_TLS_CERT_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/fullchain.pem"

# 🔒 The private key file for the API server's TLS configuration. This should correspond to the certificate file specified above and must be kept secure, as it is used to establish the server's identity and encrypt communications. Ensure that this file has strict permissions to prevent unauthorized access.
# The private key file should be generated securely and stored in a location that is not accessible to unauthorized users. It is critical to the security of your API server, as it is used to establish the server's identity and encrypt communications with clients. Make sure that this file is properly referenced in your API server configuration and that it is protected with appropriate permissions to prevent unauthorized access or compromise.
API_TLS_KEY_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/privkey.pem"

# 📊 The path to the CSV file where certbot stores information about issued certificates. This file is used by the API server to track and manage the certificates that have been issued for the REPO_FQDN. Ensure that this path is correct and that certbot has the necessary permissions to read and write to this file, as it is critical for the proper functioning of your certificate management system.
# The API server will use this CSV file to determine which certificates are currently valid, when they expire, and to manage the renewal process. Make sure that certbot is configured to use this path for storing certificate information, and that it is properly maintained to ensure that your API server can effectively manage your SSL/TLS certificates.
API_CERT_CSV="./datastore/certbot-data/letsencrypt/certificates.csv"

# 🛠️ The certificate manager to use for issuing and renewing certificates. In this case, we are using 'certbot', which is a popular ACME client that can automate the process of obtaining and renewing SSL/TLS certificates from Let's Encrypt. Ensure that certbot is properly installed and configured in your environment to manage your certificates effectively.
# The API server will use this certificate manager to request new certificates for the REPO_FQDN and to renew existing certificates as needed. Make sure that certbot is configured with the appropriate plugins and credentials to successfully complete the ACME challenges required for certificate issuance and renewal.
API_CERT_MANAGER="certbot"
