# ==============================================================================
# 🚀 PROJECT INFRASTRUCTURE CONFIGURATION
# ==============================================================================

# ==============================================================================
# ⚠️  MAINTENANCE NOTES
# - Changing REPO_FQDN usually requires container restart and certificate renewal.
# - Changing CA_NAME or CLIENT_NAME requires regenerating the internal mTLS PKI.
# ==============================================================================

# 🌐 Primary FQDN served by the RPM repository and reused by related services.
# Must also exist in the cert inventory CSV used by certbot.
REPO_FQDN=repo.example.com

# 🛡️ Common Name (CN) for the internal client-auth root CA.
# Keep it simple and descriptive for trust-store visibility.
CA_NAME="Internal-RPM-Repo-CA"

# 👤 Default client identity CN used for mTLS testing/bootstrap.
CLIENT_NAME="mtls-client-identity"

# ==============================================================================
# 🔐 CERT MANAGER API SETTINGS
# These variables map to the inputs required by the cert-manager-api binary.
# ==============================================================================

# TCP port for the API service.
API_PORT=8000

# File containing allowed client certificate CNs for mTLS auth.
# One CN per line.
API_MTLS_ALLOWED_CNS_FILE="./api/mtls-api-clients.txt"

# File containing allowed or denied client IPs/CIDRs for API access control.
# One IP or CIDR per line.
API_MTLS_IPS_FILE="./api/mtls-api-clients-ip.txt"

# CA certificate used by the API to verify incoming client certificates.
API_MTLS_CA_FILE="./secrets/api-secrets/pki_mtls_material/ca.crt"

# Server certificate presented by the API.
# Prefer the real certificate for REPO_FQDN when available.
API_TLS_CERT_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/fullchain.pem"

# Private key corresponding to API_TLS_CERT_FILE.
API_TLS_KEY_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/privkey.pem"

# Certificate inventory CSV consumed by the API / cert manager workflow.
API_CERT_CSV_FILE="./datastore/certbot-data/letsencrypt/certificates.csv"

# Certificate manager backend invoked by the API.
API_CERT_MANAGER="certbot"