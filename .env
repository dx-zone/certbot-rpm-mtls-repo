# ==============================================================================
# 🚀 PROJECT INFRASTRUCTURE CONFIGURATION
# ==============================================================================

# ==============================================================================
# ⚠️  MAINTENANCE NOTES
# - Changing REPO_FQDN usually requires container restart and certificate renewal.
# - Changing any mTLS CA/client identity usually requires PKI regeneration.
# - Long term, this project should move fully to service-specific variables
#   (RPMREPO_* and API_*) to avoid mixing trust domains.
# ==============================================================================

# 🌐 Primary FQDN used by the RPM repository and related services.
# This value should also exist in the cert inventory CSV used by certbot.
REPO_FQDN=repo.example.com

# ==============================================================================
# 🔐 LEGACY / SHARED DEFAULTS
# These are the current project-wide defaults still used by existing scripts.
# Keep them for backward compatibility until the full refactor is complete.
# ==============================================================================

# 🛡️ Legacy default root CA Common Name (CN) for RPM repository mTLS.
CA_NAME="Internal-RPM-Repo-CA"

# 👤 Legacy default client identity CN used for RPM repository bootstrap/testing.
CLIENT_NAME="mtls-client-identity"

# ==============================================================================
# 📦 RPM REPOSITORY mTLS SETTINGS
# Dedicated trust settings for the RPM repository.
# TODO: Refactor compose files, Dockerfiles, and scripts to use these directly.
# ==============================================================================

# Root CA name used to sign client certificates trusted by rpmrepo.
RPMREPO_MTLS_CA_NAME="Internal-RPM-Repo-CA"

# Default client CN used by systems that authenticate to rpmrepo.
RPMREPO_MTLS_CLIENT_NAME="mtls-client-identity"

# ==============================================================================
# 🔐 CERT MANAGER API SETTINGS
# These variables map to the inputs required by the cert-manager-api binary.
# ==============================================================================

# TCP port used by the API service.
API_PORT=8000

# Certificate manager backend invoked by the API.
API_CERT_MANAGER="certbot"

# Certificate inventory CSV consumed by the API / cert-manager workflow.
API_CERT_CSV_FILE="./datastore/certbot-data/letsencrypt/certificates.csv"

# Server certificate presented by the API.
# Prefer the real certificate for REPO_FQDN when available.
API_TLS_CERT_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/fullchain.pem"

# Private key corresponding to API_TLS_CERT_FILE.
API_TLS_KEY_FILE="./datastore/certbot-data/letsencrypt/live/${REPO_FQDN}/privkey.pem"

# ==============================================================================
# 🔒 CERT MANAGER API mTLS SETTINGS
# Dedicated trust settings for systems allowed to call the API.
# Keep these separate from rpmrepo mTLS identities.
# ==============================================================================

# Root CA name used for API client authentication.
API_MTLS_CA_NAME="Internal-Cert-Manager-API-CA"

# Default client CN for automation systems calling the API.
API_MTLS_CLIENT_NAME="cert-manager-automation-client"

# CA certificate used by the API to verify incoming client certificates.
API_MTLS_CA_FILE="./secrets/api-secrets/pki_mtls_material/ca.crt"

# File containing allowed client certificate CNs for API mTLS auth.
# One CN per line.
API_MTLS_ALLOWED_CNS_FILE="./api/mtls-api-clients-cn.txt"

# File containing allowed or denied client IPs/CIDRs for API access control.
# One IP or CIDR per line.
API_MTLS_IPS_FILE="./api/mtls-api-clients-ip.txt"